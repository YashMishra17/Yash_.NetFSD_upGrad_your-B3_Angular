@model Employee

<h2>Edit Employee</h2>
<hr />


<form method="post" asp-action="Edit">

    <div class="form-group">
        <label asp-for="Empno" class="form-label"></label>
        <input asp-for="Empno" class="form-control" readonly />
    </div>

    <div class="form-group">
        <label asp-for="Ename" class="form-label"></label>
        <input asp-for="Ename" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Job"></label>
        <input asp-for="Job" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Salary"></label>
        <input asp-for="Salary" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Deptno"></label>
        <input asp-for="Deptno" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Edit</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>

</form>


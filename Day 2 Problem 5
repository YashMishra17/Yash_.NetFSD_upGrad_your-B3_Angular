<form>
  <label>
    Course:
    <input list="courseList" required>
    <datalist id="courseList">
      <option value="HTML">
      <option value="CSS">
      <option value="JavaScript">
    </datalist>
  </label><br><br>

  <label>
    Email:
    <input type="email" required>
  </label><br><br>

  <label>
    Skill Level:
    <meter min="0" max="10" value="6"></meter>
  </label><br><br>

  <label>
    Progress:
    <progress value="50" max="100"></progress>
  </label><br><br>

  <label>
    Experience (Years):
    <input type="number" min="0" max="10">
  </label><br><br>

  <label>
    Interest Level:
    <input type="range" min="1" max="10">
  </label><br><br>

  <button type="submit">Enroll</button>
</form>
